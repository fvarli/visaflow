# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
dist-ssr/
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Private data (NEVER commit personal information)
src/data/private/*
!src/data/private/.gitkeep
data/private/*
!data/private/.gitkeep

# User uploads and exports
uploads/
exports/

# Personal documents (by extension)
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp
*.doc
*.docx

# Test coverage
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# TypeScript cache
*.tsbuildinfo
